<Window x:Class="ColorLines.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ColorLines.Windows.Converters"
        Title="Color Lines"
        Width="1060"
        Height="760"
        MinWidth="820"
        MinHeight="620"
        Background="{DynamicResource AppBackgroundBrush}">
    <Window.InputBindings>
        <KeyBinding Key="Escape"
                    Command="{Binding EscapeCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BooleanToHiddenVisibilityConverter x:Key="BooleanToHiddenVisibilityConverter" />
        <Style x:Key="ShellViewTransitionStyle" TargetType="Grid">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0" />
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Style.Triggers>
                <Trigger Property="Visibility" Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0.96"
                                                 To="1"
                                                 Duration="0:0:0.12"
                                                 FillBehavior="Stop" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 From="6"
                                                 To="0"
                                                 Duration="0:0:0.14"
                                                 FillBehavior="Stop">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="MenuPrimaryButton" TargetType="Button">
            <Setter Property="Tag" Value="MenuPrimaryButton" />
            <Setter Property="Height" Value="54" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="{StaticResource MenuPrimaryButtonBrush}" />
            <Setter Property="Foreground" Value="#FFFFFB" />
            <Setter Property="BorderBrush" Value="{StaticResource MenuPrimaryButtonHoverBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonFrame"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonFrame" Property="Background" Value="{StaticResource MenuPrimaryButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonFrame" Property="Background" Value="{StaticResource MenuPrimaryButtonPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonFrame" Property="BorderBrush" Value="#FFFFE4B8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                            <Trigger Property="Tag" Value="SettingsSelectedButton">
                                <Setter Property="Background" Value="{StaticResource MenuPrimaryButtonBrush}" />
                                <Setter Property="Foreground" Value="#FFFFFB" />
                                <Setter Property="BorderBrush" Value="{StaticResource MenuPrimaryButtonHoverBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>

        <Style x:Key="MenuSecondaryButton" TargetType="Button">
            <Setter Property="Tag" Value="MenuSecondaryButton" />
            <Setter Property="Height" Value="46" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="{DynamicResource MenuSecondaryButtonBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CellBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonFrame"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonFrame" Property="Background" Value="{StaticResource MenuSecondaryButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonFrame" Property="Background" Value="{StaticResource MenuSecondaryButtonPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonFrame" Property="BorderBrush" Value="{StaticResource MenuPrimaryButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="Tag" Value="SettingsSelectedButton">
                                <Setter TargetName="ButtonFrame" Property="Background" Value="{StaticResource MenuPrimaryButtonBrush}" />
                                <Setter TargetName="ButtonFrame" Property="BorderBrush" Value="{StaticResource MenuPrimaryButtonHoverBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GameplayCompactButton" TargetType="Button" BasedOn="{StaticResource MenuSecondaryButton}">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Tag" Value="MenuSecondaryButton" />
        </Style>

        <Style x:Key="SettingsTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="SettingsTabItem" TargetType="TabItem">
            <Setter Property="Tag" Value="SettingsTabItem" />
            <Setter Property="Width" Value="132" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Background" Value="{StaticResource MenuSecondaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabFrame"
                                MinHeight="{TemplateBinding MinHeight}"
                                Margin="{TemplateBinding Margin}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="999">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabFrame" Property="Background" Value="{StaticResource MenuSecondaryButtonHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabFrame" Property="Background" Value="{StaticResource MenuPrimaryButtonBrush}" />
                                <Setter TargetName="TabFrame" Property="BorderBrush" Value="{StaticResource MenuPrimaryButtonHoverBrush}" />
                                <Setter Property="Foreground" Value="#FFFFFB" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="TabFrame" Property="BorderBrush" Value="{StaticResource MenuPrimaryButtonHoverBrush}" />
                                <Setter TargetName="TabFrame" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BoardCellButton" TargetType="Button">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource CellBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CellBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CellFrame"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CellFrame" Property="Background" Value="{DynamicResource CellHoverBrush}" />
                                <Setter TargetName="CellFrame" Property="BorderBrush" Value="#99D7839A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="MainMenuView"
              Margin="28"
              Style="{StaticResource ShellViewTransitionStyle}"
              Visibility="{Binding IsMainMenuVisible, Converter={StaticResource BooleanToHiddenVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>
            <Border x:Name="MenuBackdrop"
                    Grid.ColumnSpan="2"
                    Background="{StaticResource MenuBackdropBrush}"
                    CornerRadius="18" />

            <Grid x:Name="MenuHeroArea"
                  Grid.Column="0"
                  Margin="30,0,44,0"
                  VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Color Lines"
                               FontSize="54"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding MenuTaglineText}"
                               Margin="0,10,0,0"
                               FontSize="18"
                               Foreground="{StaticResource TextMutedBrush}" />
                    <Border x:Name="MenuHeroBoard"
                            Margin="0,30,0,0"
                            Width="460"
                            Height="460"
                            Background="{DynamicResource BoardShadowBrush}"
                            BorderBrush="{DynamicResource BoardBorderBrush}"
                            BorderThickness="2"
                            CornerRadius="22"
                            Padding="18"
                            HorizontalAlignment="Left">
                        <Border Background="{DynamicResource BoardInnerBrush}"
                                CornerRadius="16"
                                Padding="16">
                            <UniformGrid Rows="5" Columns="5">
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4">
                                <Image x:Name="MenuPreviewCatOrange"
                                       Source="{Binding MenuPreviewOrangeAssetPath}"
                                       Width="56"
                                       Height="56"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4">
                                <Image x:Name="MenuPreviewCatBlueGray"
                                       Source="{Binding MenuPreviewBlueGrayAssetPath}"
                                       Width="56"
                                       Height="56"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4">
                                <Image x:Name="MenuPreviewCatTuxedo"
                                       Source="{Binding MenuPreviewTuxedoAssetPath}"
                                       Width="56"
                                       Height="56"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4">
                                <Image x:Name="MenuPreviewCatCalico"
                                       Source="{Binding MenuPreviewCalicoAssetPath}"
                                       Width="56"
                                       Height="56"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4">
                                <Image x:Name="MenuPreviewCatWhite"
                                       Source="{Binding MenuPreviewWhiteAssetPath}"
                                       Width="56"
                                       Height="56"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4">
                                <Image x:Name="MenuPreviewCatGray"
                                       Source="{Binding MenuPreviewGrayAssetPath}"
                                       Width="56"
                                       Height="56"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>
                            <Border Background="{DynamicResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            </UniformGrid>
                        </Border>
                    </Border>
                </StackPanel>
            </Grid>

            <Border x:Name="MenuCommandPanel"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="28"
                    MinWidth="320">
                <StackPanel>
                    <TextBlock x:Name="ReadyToPlayText"
                               Text="{Binding ReadyToPlayText}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <StackPanel x:Name="MenuStatusStrip">
                        <TextBlock Text="{Binding BestScoreSummaryText}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock x:Name="MenuSaveSummary"
                                   Text="{Binding SaveSummaryText}"
                                   Margin="0,8,0,0"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock x:Name="MenuNoticeText"
                                   Text="{Binding MenuNoticeText}"
                                   Margin="0,8,0,0"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding ThemeSummaryText}"
                                   Margin="0,8,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding AnimationSummaryText}"
                                   Margin="0,4,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding SoundSummaryText}"
                                   Margin="0,4,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                    <Button x:Name="ContinueButton"
                            Content="{Binding ContinueText}"
                            AutomationProperties.Name="{Binding ContinueText}"
                            Command="{Binding ContinueCommand}"
                            Style="{StaticResource MenuPrimaryButton}"
                            Margin="0,26,0,0"
                            />
                    <Button x:Name="MenuNewGameButton"
                            Content="{Binding NewGameText}"
                            AutomationProperties.Name="{Binding NewGameText}"
                            Command="{Binding NewGameCommand}"
                            Style="{StaticResource MenuSecondaryButton}"
                            Margin="0,10,0,0"
                            />
                    <Border x:Name="MenuNewGameConfirmPanel"
                            Margin="0,10,0,0"
                            Padding="14,12"
                            Background="{StaticResource SettingsRowBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            FocusManager.FocusedElement="{Binding ElementName=MenuNewGameCancelButton}"
                            Visibility="{Binding IsNewGameConfirmVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding NewGameConfirmTitle}"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding NewGameConfirmBody}"
                                       Margin="0,5,0,0"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextMutedBrush}" />
                            <UniformGrid Rows="1"
                                         Columns="2"
                                         Margin="0,10,0,0">
                                <Button x:Name="MenuNewGameCancelButton"
                                        Content="{Binding KeepPlayingText}"
                                        Command="{Binding CancelNewGameCommand}"
                                        Style="{StaticResource GameplayCompactButton}"
                                        Margin="0,0,5,0" />
                                <Button x:Name="MenuNewGameConfirmButton"
                                        Content="{Binding StartAnywayText}"
                                        Command="{Binding ConfirmNewGameCommand}"
                                        Style="{StaticResource GameplayCompactButton}"
                                        Margin="5,0,0,0" />
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                    <Button x:Name="MenuSettingsButton"
                            Content="{Binding SettingsText}"
                            AutomationProperties.Name="{Binding SettingsText}"
                            Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource MenuSecondaryButton}"
                            Margin="0,10,0,0"
                            />
                    <Button x:Name="ExitButton"
                            Content="{Binding ExitText}"
                            Command="{Binding ExitCommand}"
                            Style="{StaticResource MenuSecondaryButton}"
                            Margin="0,10,0,0"
                            />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="GameplayView"
              Margin="28"
              Style="{StaticResource ShellViewTransitionStyle}"
              Visibility="{Binding IsPlayingVisible, Converter={StaticResource BooleanToHiddenVisibilityConverter}}">
            <Grid x:Name="GameplayShell">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <Grid x:Name="GameplayBoardArea"
                      Grid.Column="0"
                      Margin="0,0,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="MainBoardFrame"
                            Background="{DynamicResource BoardInnerBrush}"
                            BorderBrush="{DynamicResource BoardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="24"
                            Padding="16">
                        <Border Background="{DynamicResource BoardInnerBrush}"
                                CornerRadius="20"
                                Padding="10">
                            <Viewbox Stretch="Uniform">
                                <ItemsControl ItemsSource="{Binding Game.Cells}" Width="560" Height="560">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="{Binding DataContext.Game.BoardSize, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                         Columns="{Binding DataContext.Game.BoardSize, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource BoardCellButton}"
                                    Command="{Binding DataContext.Game.SelectCellCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    MouseEnter="BoardCellPointerEntered"
                                    MouseLeave="BoardCellPointerLeft">
                                <Grid x:Name="BoardCellContent"
                                      Width="{Binding DataContext.Game.BoardCellVisualSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                      Height="{Binding DataContext.Game.BoardCellVisualSize, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <Border x:Name="ReachableTargetGlow"
                                            Margin="13"
                                            CornerRadius="16"
                                            Background="#99FFF2D8"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsReachableTarget}" Value="True">
                                                        <Setter Property="Opacity" Value="0.34" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsReachableTarget}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.Game.ThemeId, RelativeSource={RelativeSource AncestorType=Window}}" Value="3DCatTokens" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Margin" Value="15" />
                                                        <Setter Property="CornerRadius" Value="18" />
                                                        <Setter Property="Background" Value="#FFFFE9B8" />
                                                        <Setter Property="Opacity" Value="0.2" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border x:Name="PathPreviewGlow"
                                            Margin="11"
                                            CornerRadius="14"
                                            Background="#AA8FD8D1"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPathPreview}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard x:Name="PathPreviewFlowStoryboard">
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.20"
                                                                                     To="0.44"
                                                                                     Duration="0:0:0.42"
                                                                                     AutoReverse="True"
                                                                                     RepeatBehavior="Forever" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                        <DataTrigger.ExitActions>
                                                            <StopStoryboard BeginStoryboardName="PathPreviewFlowStoryboard" />
                                                        </DataTrigger.ExitActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border x:Name="ClearOpportunityGlow"
                                            Margin="8"
                                            CornerRadius="17"
                                            BorderBrush="#FFD7839A"
                                            BorderThickness="2"
                                            Background="#33D7839A"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsClearOpportunity}" Value="True">
                                                        <Setter Property="Opacity" Value="0.78" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border x:Name="RecommendedClearTargetGlow"
                                            Margin="5"
                                            CornerRadius="18"
                                            BorderBrush="#FFFFB65A"
                                            BorderThickness="3"
                                            Background="#26FFB65A"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRecommendedClearTarget}" Value="True">
                                                        <Setter Property="Opacity" Value="0.9" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border x:Name="PathPreviewTargetGlow"
                                            Margin="7"
                                            CornerRadius="17"
                                            BorderBrush="#FFFFF4B8"
                                            BorderThickness="2"
                                            Background="#33FFFFFF"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPathPreviewTarget}" Value="True">
                                                        <Setter Property="Opacity" Value="0.82" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border x:Name="MovePathPulseGlow"
                                            Margin="10"
                                            CornerRadius="15"
                                            Background="#FF8FD8D1"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding WasMovePath}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.Game.IsFullAnimation, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <MultiDataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.58"
                                                                                     To="0"
                                                                                     Duration="0:0:0.36" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </MultiDataTrigger.EnterActions>
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding WasMovePath}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.Game.IsFullAnimation, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Opacity" Value="0" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border x:Name="ClearFeedbackGlow"
                                            Background="#33FF8BA7"
                                            CornerRadius="12"
                                            Margin="3"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding WasCleared}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.Game.IsFullAnimation, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <MultiDataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.62"
                                                                                     To="0"
                                                                                     Duration="0:0:0.28" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </MultiDataTrigger.EnterActions>
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding WasCleared}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.Game.IsFullAnimation, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Opacity" Value="0" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border x:Name="ClearPulseGlow"
                                            Background="#77FF7DA4"
                                            BorderBrush="#FFFFD0DD"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Margin="5"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding WasCleared}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.Game.IsFullAnimation, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <MultiDataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.98"
                                                                                     To="0"
                                                                                     Duration="0:0:0.42" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </MultiDataTrigger.EnterActions>
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding WasCleared}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.Game.IsFullAnimation, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Opacity" Value="0" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border x:Name="RejectFeedbackGlow"
                                            Background="#36D94B4B"
                                            CornerRadius="12"
                                            Margin="3"
                                            IsHitTestVisible="False">
                                        <Border.RenderTransform>
                                            <TranslateTransform />
                                        </Border.RenderTransform>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding WasRejectedTarget}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.Game.IsFullAnimation, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <MultiDataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.68"
                                                                                     To="0"
                                                                                     Duration="0:0:0.28" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </MultiDataTrigger.EnterActions>
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding WasRejectedTarget}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.Game.IsFullAnimation, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Opacity" Value="0" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Ellipse x:Name="SpawnFeedbackGlow"
                                             Width="40"
                                             Height="28"
                                             VerticalAlignment="Bottom"
                                             Fill="#5562B96C"
                                             IsHitTestVisible="False">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding WasSpawned}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.Game.IsFullAnimation, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <MultiDataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.74"
                                                                                     To="0"
                                                                                     Duration="0:0:0.34" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </MultiDataTrigger.EnterActions>
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding WasSpawned}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.Game.IsFullAnimation, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Opacity" Value="0" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <Ellipse x:Name="MoveFeedbackGlow"
                                             Width="40"
                                             Height="28"
                                             VerticalAlignment="Bottom"
                                             Fill="#5568A9FF"
                                             IsHitTestVisible="False">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding WasMovedTo}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.Game.IsFullAnimation, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <MultiDataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.74"
                                                                                     To="0"
                                                                                     Duration="0:0:0.32" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </MultiDataTrigger.EnterActions>
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding WasMovedTo}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.Game.IsFullAnimation, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Opacity" Value="0" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <Ellipse x:Name="PieceBase"
                                             VerticalAlignment="Bottom"
                                             Fill="#55FFF4DC"
                                             IsHitTestVisible="False">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Width" Value="40" />
                                                <Setter Property="Height" Value="23" />
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOccupied}" Value="True">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsOccupied}" Value="True" />
                                                            <Condition Binding="{Binding Piece.UsesEmbeddedShadow}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Opacity" Value="0.28" />
                                                        <Setter Property="Width" Value="42" />
                                                        <Setter Property="Height" Value="18" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <Ellipse x:Name="PieceShadow"
                                             VerticalAlignment="Bottom"
                                             Fill="#261F1712"
                                             IsHitTestVisible="False">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Width" Value="36" />
                                                <Setter Property="Height" Value="16" />
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOccupied}" Value="True">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsOccupied}" Value="True" />
                                                            <Condition Binding="{Binding Piece.UsesEmbeddedShadow}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Opacity" Value="0.12" />
                                                        <Setter Property="Width" Value="34" />
                                                        <Setter Property="Height" Value="12" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <Ellipse x:Name="SelectedPieceHalo"
                                             Width="44"
                                             Height="36"
                                             VerticalAlignment="Bottom"
                                             Fill="#44FFD6E1"
                                             IsHitTestVisible="False">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Opacity" Value="0.68" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsSelected}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.Game.IsFullAnimation, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <MultiDataTrigger.EnterActions>
                                                            <BeginStoryboard x:Name="SelectedPieceHaloStoryboard">
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.42"
                                                                                     To="0.82"
                                                                                     Duration="0:0:0.72"
                                                                                     AutoReverse="True"
                                                                                     RepeatBehavior="Forever" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </MultiDataTrigger.EnterActions>
                                                        <MultiDataTrigger.ExitActions>
                                                            <StopStoryboard BeginStoryboardName="SelectedPieceHaloStoryboard" />
                                                        </MultiDataTrigger.ExitActions>
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsSelected}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.Game.IsFullAnimation, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Opacity" Value="0.68" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <Grid x:Name="PieceActor"
                                          RenderTransformOrigin="0.5,0.85"
                                          IsHitTestVisible="False">
                                        <Grid.RenderTransform>
                                            <TranslateTransform Y="0" />
                                        </Grid.RenderTransform>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Margin" Value="0,-3,0,3" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid x:Name="PieceScaleActor"
                                              RenderTransformOrigin="0.5,0.85">
                                            <Grid.RenderTransform>
                                                <ScaleTransform ScaleX="1" ScaleY="1" />
                                            </Grid.RenderTransform>
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding WasMovedTo}" Value="True" />
                                                                <Condition Binding="{Binding DataContext.Game.IsFullAnimation, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                                            </MultiDataTrigger.Conditions>
                                                            <MultiDataTrigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                         From="0.35"
                                                                                         To="1"
                                                                                         Duration="0:0:0.16" />
                                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                                         From="0.88"
                                                                                         To="1"
                                                                                         Duration="0:0:0.16" />
                                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                                         From="0.88"
                                                                                         To="1"
                                                                                         Duration="0:0:0.16" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </MultiDataTrigger.EnterActions>
                                                        </MultiDataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding WasSpawned}" Value="True" />
                                                                <Condition Binding="{Binding DataContext.Game.IsFullAnimation, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                                            </MultiDataTrigger.Conditions>
                                                            <MultiDataTrigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                         From="0.05"
                                                                                         To="1"
                                                                                         Duration="0:0:0.18" />
                                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                                         From="0.72"
                                                                                         To="1"
                                                                                         Duration="0:0:0.18" />
                                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                                         From="0.72"
                                                                                         To="1"
                                                                                         Duration="0:0:0.18" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </MultiDataTrigger.EnterActions>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Image x:Name="PieceImage"
                                                   Source="{Binding Piece.AssetPath}"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Width" Value="{Binding DataContext.Game.BoardPieceImageSize, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                        <Setter Property="Height" Value="{Binding DataContext.Game.BoardPieceImageSize, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                        <Setter Property="Opacity" Value="0" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOccupied}" Value="True">
                                                                <Setter Property="Opacity" Value="1" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Viewbox>
                        </Border>
                    </Border>
                </Grid>

                <Border x:Name="GameplayHudPanel"
                        Grid.Column="1"
                        MaxWidth="320"
                        Background="{StaticResource GameplayHudBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="20"
                        VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border x:Name="GameplayStatusBanner"
                                Grid.Row="0"
                                MinHeight="58"
                                Background="{StaticResource GameplayHudAccentBrush}"
                                CornerRadius="10"
                                Padding="14,10">
                            <StackPanel>
                                <TextBlock Text="{Binding Game.StatusText}"
                                           FontSize="15"
                                           LineHeight="19"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock x:Name="SelectedActionSummaryText"
                                           Text="{Binding Game.SelectedActionSummaryText}"
                                           Margin="0,5,0,0"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource TextMutedBrush}" />
                                <TextBlock x:Name="MovePreviewText"
                                           Text="{Binding Game.MovePreviewText}"
                                           Margin="0,5,0,0"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource ScoreAccentBrush}" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="GameplayScoreBlock"
                                Grid.Row="2"
                                Background="{StaticResource PanelBackgroundBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="18,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="ScoreLabelText"
                                               Text="{Binding ScoreText}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBlock Text="{Binding Game.Score}"
                                               FontSize="42"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding BestText}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMutedBrush}" />
                                </StackPanel>
                                <Border x:Name="ScoreDeltaBadge"
                                        Grid.Column="1"
                                        MinWidth="52"
                                        Height="40"
                                        Background="{StaticResource GameplayHudAccentBrush}"
                                        CornerRadius="10"
                                        VerticalAlignment="Bottom">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Opacity" Value="0" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Game.ShowScoreDelta}" Value="True" />
                                                        <Condition Binding="{Binding Game.IsFullAnimation}" Value="True" />
                                                    </MultiDataTrigger.Conditions>
                                                    <MultiDataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 From="1"
                                                                                 To="0"
                                                                                 Duration="0:0:0.85" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </MultiDataTrigger.EnterActions>
                                                </MultiDataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Game.ShowScoreDelta}" Value="True" />
                                                        <Condition Binding="{Binding Game.IsFullAnimation}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Opacity" Value="0.85" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Game.ScoreDeltaBadgeText}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="21"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource ScoreAccentBrush}" />
                                </Border>
                            </Grid>
                        </Border>

                        <Border x:Name="GameplayNextCatsBlock"
                                Grid.Row="4"
                                Background="{StaticResource PanelBackgroundBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="18,16">
                            <StackPanel>
                                <TextBlock x:Name="NextCatsLabelText"
                                           Text="{Binding NextCatsText}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}" />
                                <ItemsControl ItemsSource="{Binding Game.NextPieces}" Margin="0,12,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="NextCatPreviewTile"
                                                    Margin="0,0,10,0"
                                                    Background="{StaticResource GameplayHudAccentBrush}"
                                                    CornerRadius="14">
                                                <Image x:Name="NextCatPreviewImage"
                                                       Source="{Binding AssetPath}"
                                                       Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="HighQuality">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Width" Value="48" />
                                                            <Setter Property="Height" Value="48" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding UsesEmbeddedShadow}" Value="True">
                                                                    <Setter Property="Width" Value="54" />
                                                                    <Setter Property="Height" Value="54" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Width" Value="64" />
                                                        <Setter Property="Height" Value="64" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding UsesEmbeddedShadow}" Value="True">
                                                                <Setter Property="Width" Value="66" />
                                                                <Setter Property="Height" Value="66" />
                                                                <Setter Property="CornerRadius" Value="16" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border x:Name="GameplayBoardPressureBlock"
                                Grid.Row="6"
                                Background="{StaticResource PanelBackgroundBrush}"
                                CornerRadius="10"
                                Padding="18,14">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Game.BoardPressureLevel}" Value="Tight">
                                            <Setter Property="BorderBrush" Value="#99FFB65A" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Game.BoardPressureLevel}" Value="Critical">
                                            <Setter Property="BorderBrush" Value="#FFFFB65A" />
                                            <Setter Property="BorderThickness" Value="2" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Game.ProjectedBoardPressureLevel}" Value="Tight">
                                            <Setter Property="BorderBrush" Value="#99FFB65A" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Game.ProjectedBoardPressureLevel}" Value="Critical">
                                            <Setter Property="BorderBrush" Value="#FFFFB65A" />
                                            <Setter Property="BorderThickness" Value="2" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock x:Name="BoardPressureText"
                                           Text="{Binding BoardPressureText}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <Border x:Name="BoardPressureBadge"
                                        Margin="0,7,0,2"
                                        Padding="10,4"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource GameplayHudAccentBrush}"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="9">
                                    <TextBlock x:Name="BoardPressureLevelText"
                                               Text="{Binding BoardPressureLevelText}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ScoreAccentBrush}" />
                                </Border>
                                <TextBlock x:Name="BoardSpaceText"
                                           Text="{Binding BoardSpaceText}"
                                           Margin="0,4,0,0"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource TextMutedBrush}" />
                                <TextBlock x:Name="ProjectedBoardPressureText"
                                           Text="{Binding ProjectedBoardPressureText}"
                                           Margin="0,4,0,0"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource TextMutedBrush}" />
                                <TextBlock x:Name="BoardPressureAdviceText"
                                           Text="{Binding BoardPressureAdviceText}"
                                           Margin="0,6,0,0"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <Grid x:Name="BoardPressureMeter"
                                      Width="280"
                                      Height="8"
                                      Margin="0,9,0,0">
                                    <Border Background="{StaticResource GameplayHudAccentBrush}"
                                            CornerRadius="4" />
                                    <Border x:Name="ProjectedBoardPressureMeterFill"
                                            Width="{Binding Game.ProjectedBoardPressureMeterWidth}"
                                            HorizontalAlignment="Left"
                                            Background="#44FFB65A"
                                            CornerRadius="4" />
                                    <Border x:Name="BoardPressureMeterFill"
                                            Width="{Binding Game.BoardPressureMeterWidth}"
                                            HorizontalAlignment="Left"
                                            Background="{StaticResource ScoreAccentBrush}"
                                            CornerRadius="4" />
                                </Grid>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,10,0,0"
                                            VerticalAlignment="Center">
                                    <Border x:Name="ReachableLegendSwatch"
                                            Width="13"
                                            Height="13"
                                            CornerRadius="6"
                                            Background="#FFFFE1A8"
                                            Opacity="0.55"
                                            VerticalAlignment="Center" />
                                    <Border x:Name="ClearLegendSwatch"
                                            Width="13"
                                            Height="13"
                                            Margin="8,0,0,0"
                                            CornerRadius="6"
                                            BorderBrush="#FFFFB65A"
                                            BorderThickness="2"
                                            Background="#33FFB65A"
                                            VerticalAlignment="Center" />
                                    <Border x:Name="PathLegendSwatch"
                                            Width="13"
                                            Height="13"
                                            Margin="8,0,8,0"
                                            CornerRadius="6"
                                            Background="#FF7AC7C4"
                                            Opacity="0.75"
                                            VerticalAlignment="Center" />
                                    <TextBlock x:Name="HintLegendText"
                                               Text="{Binding HintLegendText}"
                                               FontSize="12"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <StackPanel x:Name="GameplayActionBar"
                                    Grid.Row="8">
                            <Button x:Name="GameplayMenuButton"
                                    Content="{Binding MenuText}"
                                    Command="{Binding OpenPauseMenuCommand}"
                                    Style="{StaticResource GameplayCompactButton}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="PauseMenuView"
              Background="#66000000"
              Style="{StaticResource ShellViewTransitionStyle}"
              Visibility="{Binding IsPauseMenuVisible, Converter={StaticResource BooleanToHiddenVisibilityConverter}}">
            <Border x:Name="PauseMenuPanel"
                    Width="420"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{StaticResource SettingsSurfaceBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="28">
                <StackPanel>
                    <TextBlock Text="{Binding GameMenuTitle}"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding PauseSubtitle}"
                               Margin="0,8,0,22"
                               FontSize="15"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" />
                    <Border x:Name="PauseBoardSummaryPanel"
                            Margin="0,0,0,18"
                            Padding="14,12"
                            Background="{StaticResource GameplayHudAccentBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock x:Name="PauseRunSummaryText"
                                       Text="{Binding PauseRunSummaryText}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="PauseBoardPressureText"
                                       Text="{Binding BoardPressureText}"
                                       Margin="0,5,0,0"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <StackPanel x:Name="PauseMenuActionList">
                        <Button x:Name="PauseContinueButton"
                                Content="{Binding ContinueText}"
                                Command="{Binding BackToGameCommand}"
                                Style="{StaticResource MenuPrimaryButton}" />
                        <Button x:Name="PauseSaveButton"
                                Content="{Binding SaveGameText}"
                                Command="{Binding SaveGameCommand}"
                                Style="{StaticResource GameplayCompactButton}"
                                Margin="0,10,0,0" />
                        <TextBlock x:Name="PauseSaveStatusText"
                                   Text="{Binding PauseSaveStatusText}"
                                   MinHeight="18"
                                   Margin="0,6,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" />
                        <Button x:Name="PauseSettingsButton"
                                Content="{Binding SettingsText}"
                                Command="{Binding OpenSettingsCommand}"
                                Style="{StaticResource GameplayCompactButton}"
                                Margin="0,10,0,0" />
                        <Button x:Name="PauseEndGameButton"
                                Content="{Binding EndGameText}"
                                Command="{Binding EndGameCommand}"
                                Style="{StaticResource GameplayCompactButton}"
                                Margin="0,10,0,0" />
                        <Border x:Name="EndGameConfirmPanel"
                                Margin="0,12,0,0"
                                Padding="14"
                                FocusManager.FocusedElement="{Binding ElementName=EndGameCancelButton}"
                                Background="{StaticResource MenuSecondaryButtonBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Visibility="{Binding IsEndGameConfirmVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="{Binding EndGameConfirmTitle}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding EndGameConfirmBody}"
                                           Margin="0,6,0,12"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextAlignment="Center" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="EndGameCancelButton"
                                            Grid.Column="0"
                                            Content="{Binding KeepPlayingText}"
                                            Command="{Binding CancelEndGameCommand}"
                                            Style="{StaticResource GameplayCompactButton}" />
                                    <Button x:Name="EndGameConfirmButton"
                                            Grid.Column="2"
                                            Content="{Binding EndGameText}"
                                            Command="{Binding ConfirmEndGameCommand}"
                                            Style="{StaticResource GameplayCompactButton}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Button x:Name="PauseBackToMenuButton"
                                Content="{Binding ReturnToMainMenuText}"
                                Command="{Binding RequestBackToMenuCommand}"
                                Style="{StaticResource GameplayCompactButton}"
                                Margin="0,10,0,0" />
                        <Border x:Name="ReturnToMenuConfirmPanel"
                                Margin="0,12,0,0"
                                Padding="14"
                                FocusManager.FocusedElement="{Binding ElementName=ReturnToMenuCancelButton}"
                                Background="{StaticResource MenuSecondaryButtonBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Visibility="{Binding IsReturnToMenuConfirmVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="{Binding ReturnToMenuConfirmTitle}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding ReturnToMenuConfirmBody}"
                                           Margin="0,6,0,12"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextAlignment="Center" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="ReturnToMenuCancelButton"
                                            Grid.Column="0"
                                            Content="{Binding StayInGameText}"
                                            Command="{Binding CancelBackToMenuCommand}"
                                            Style="{StaticResource GameplayCompactButton}" />
                                    <Button x:Name="ReturnToMenuConfirmButton"
                                            Grid.Column="2"
                                            Content="{Binding ReturnAnywayText}"
                                            Command="{Binding ConfirmBackToMenuCommand}"
                                            Style="{StaticResource GameplayCompactButton}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="SettingsView"
              Margin="28"
              Style="{StaticResource ShellViewTransitionStyle}"
              Visibility="{Binding IsSettingsVisible, Converter={StaticResource BooleanToHiddenVisibilityConverter}}">
            <Grid x:Name="SettingsShell">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.85*" />
                    <ColumnDefinition Width="1.15*" />
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="SettingsHeader"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Margin="8,0,28,0">
                    <TextBlock Text="{Binding SettingsTitle}"
                               FontSize="48"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding SettingsSubtitle}"
                               Margin="0,10,0,0"
                               FontSize="18"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextMutedBrush}" />
                    <Border Margin="0,28,0,0"
                            Background="{StaticResource GameplayHudAccentBrush}"
                            CornerRadius="12"
                            Padding="18,14"
                            MaxWidth="360"
                            HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="{Binding ThemeSummaryText}"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding BestScoreSummaryText}"
                                       Margin="0,6,0,0"
                                       FontSize="14"
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border x:Name="SettingsContentPanel"
                        Grid.Column="1"
                        MaxWidth="520"
                        Background="{StaticResource SettingsSurfaceBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="28"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TabControl x:Name="SettingsTabs"
                                    MinHeight="382"
                                    Style="{StaticResource SettingsTabControl}">
                            <TabItem x:Name="GameplaySettingsTab"
                                     Header="{Binding GameplayTabText}"
                                     Style="{StaticResource SettingsTabItem}">
                                <StackPanel Margin="0,14,0,0">
                                    <Border x:Name="DifficultySettingRow"
                                            MinHeight="84"
                                            Background="{StaticResource SettingsRowBrush}"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="18,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="240" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DifficultyText}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock x:Name="DifficultySummaryText"
                                                           Text="{Binding DifficultySummaryText}"
                                                           Margin="0,5,0,0"
                                                           FontSize="14"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>
                                            <UniformGrid Grid.Column="1"
                                                         Rows="1"
                                                         Columns="3"
                                                         VerticalAlignment="Center">
                                                <Button x:Name="SettingsEasyButton"
                                                        Content="{Binding EasyText}"
                                                        Command="{Binding Game.SetDifficultyCommand}"
                                                        CommandParameter="Easy"
                                                        Tag="{Binding EasyDifficultyButtonTag}"
                                                        Style="{StaticResource GameplayCompactButton}"
                                                        Margin="0,0,5,0" />
                                                <Button x:Name="SettingsNormalButton"
                                                        Content="{Binding NormalText}"
                                                        Command="{Binding Game.SetDifficultyCommand}"
                                                        CommandParameter="Normal"
                                                        Tag="{Binding NormalDifficultyButtonTag}"
                                                        Style="{StaticResource GameplayCompactButton}"
                                                        Margin="5,0,5,0" />
                                                <Button x:Name="SettingsHardButton"
                                                        Content="{Binding HardText}"
                                                        Command="{Binding Game.SetDifficultyCommand}"
                                                        CommandParameter="Hard"
                                                        Tag="{Binding HardDifficultyButtonTag}"
                                                        Style="{StaticResource GameplayCompactButton}"
                                                        Margin="5,0,0,0" />
                                            </UniformGrid>
                                        </Grid>
                                    </Border>

                                    <Border x:Name="PathHintsSettingRow"
                                            MinHeight="84"
                                            Margin="0,12,0,0"
                                            Background="{StaticResource SettingsRowBrush}"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="18,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="260" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding PathHintsText}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Text="{Binding PathHintsStatusText}"
                                                           Margin="0,5,0,0"
                                                           FontSize="14"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>
                                            <Button x:Name="SettingsTogglePathHintsButton"
                                                    Grid.Column="1"
                                                    Content="{Binding TogglePathHintsText}"
                                                    Command="{Binding Game.TogglePathHintsCommand}"
                                                    Style="{StaticResource GameplayCompactButton}"
                                                    VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <Border x:Name="AutoSaveSettingRow"
                                            MinHeight="84"
                                            Margin="0,12,0,0"
                                            Background="{StaticResource SettingsRowBrush}"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="18,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="160" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding AutoSaveText}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Text="{Binding AutoSaveStatusText}"
                                                           Margin="0,5,0,0"
                                                           FontSize="14"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>
                                            <Button x:Name="SettingsToggleAutoSaveButton"
                                                    Grid.Column="1"
                                                    Content="{Binding ToggleAutoSaveText}"
                                                    Command="{Binding Game.ToggleAutoSaveCommand}"
                                                    Style="{StaticResource GameplayCompactButton}"
                                                    VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </TabItem>

                            <TabItem x:Name="AudioSettingsTab"
                                     Header="{Binding AudioTabText}"
                                     Style="{StaticResource SettingsTabItem}">
                                <StackPanel Margin="0,14,0,0">
                                    <Border x:Name="SoundSettingRow"
                                            MinHeight="84"
                                            Background="{StaticResource SettingsRowBrush}"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="18,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="160" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SoundText}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Text="{Binding SoundEnabledText}"
                                                           Margin="0,5,0,0"
                                                           FontSize="14"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>
                                            <Button x:Name="SettingsToggleSoundButton"
                                                    Grid.Column="1"
                                                    Content="{Binding ToggleSoundText}"
                                                    Command="{Binding Game.ToggleSoundCommand}"
                                                    Style="{StaticResource GameplayCompactButton}"
                                                    VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </TabItem>

                            <TabItem x:Name="DisplaySettingsTab"
                                     Header="{Binding DisplayTabText}"
                                     Style="{StaticResource SettingsTabItem}">
                                <StackPanel Margin="0,14,0,0">
                                    <Border x:Name="AnimationSettingRow"
                                            MinHeight="84"
                                            Background="{StaticResource SettingsRowBrush}"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="18,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="160" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding AnimationText}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Text="{Binding CurrentAnimationText}"
                                                           Margin="0,5,0,0"
                                                           FontSize="14"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>
                                            <Button x:Name="SettingsToggleAnimationButton"
                                                    Grid.Column="1"
                                                    Content="{Binding Game.AnimationToggleText}"
                                                    Command="{Binding Game.ToggleAnimationCommand}"
                                                    Style="{StaticResource GameplayCompactButton}"
                                                    VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <Border x:Name="ThemeSettingRow"
                                            MinHeight="84"
                                            Margin="0,12,0,0"
                                            Background="{StaticResource SettingsRowBrush}"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="18,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="160" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ThemeText}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Text="{Binding ThemeCurrentText}"
                                                           Margin="0,5,0,0"
                                                           FontSize="14"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>
                                            <UniformGrid Grid.Column="1"
                                                         Rows="1"
                                                         Columns="2"
                                                         VerticalAlignment="Center">
                                                <Button x:Name="SettingsCozyBoardThemeButton"
                                                        Content="{Binding CozyBoardThemeText}"
                                                        Command="{Binding Game.SetThemeCommand}"
                                                        CommandParameter="CozyBoard"
                                                        ToolTip="{Binding ThemeUnavailableText}"
                                                        Tag="{Binding CozyBoardThemeButtonTag}"
                                                        Style="{StaticResource GameplayCompactButton}"
                                                        Margin="0,0,6,0" />
                                                <Button x:Name="SettingsThreeDCatTokensThemeButton"
                                                        Content="{Binding ThreeDCatTokensThemeText}"
                                                        Command="{Binding Game.SetThemeCommand}"
                                                        CommandParameter="3DCatTokens"
                                                        ToolTip="{Binding ThemeUnavailableText}"
                                                        Tag="{Binding ThreeDCatTokensThemeButtonTag}"
                                                        Style="{StaticResource GameplayCompactButton}"
                                                        Margin="6,0,0,0" />
                                            </UniformGrid>
                                        </Grid>
                                    </Border>

                                    <Border x:Name="LanguageSettingRow"
                                            MinHeight="84"
                                            Margin="0,12,0,0"
                                            Background="{StaticResource SettingsRowBrush}"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="18,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="220" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding LanguageText}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Text="{Binding LanguageSummaryText}"
                                                           Margin="0,5,0,0"
                                                           FontSize="14"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>
                                            <UniformGrid Grid.Column="1"
                                                         Rows="1"
                                                         Columns="2"
                                                         VerticalAlignment="Center">
                                                <Button x:Name="SettingsEnglishButton"
                                                        Content="{Binding EnglishLanguageText}"
                                                        Command="{Binding SetLanguageCommand}"
                                                        CommandParameter="en"
                                                        Tag="{Binding EnglishLanguageButtonTag}"
                                                        Style="{StaticResource GameplayCompactButton}"
                                                        Margin="0,0,6,0" />
                                                <Button x:Name="SettingsChineseButton"
                                                        Content="{Binding ChineseLanguageText}"
                                                        Command="{Binding SetLanguageCommand}"
                                                        CommandParameter="zh"
                                                        Tag="{Binding ChineseLanguageButtonTag}"
                                                        Style="{StaticResource GameplayCompactButton}"
                                                        Margin="6,0,0,0" />
                                            </UniformGrid>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </TabItem>
                        </TabControl>

                        <StackPanel x:Name="SettingsActionBar"
                                    Grid.Row="2">
                            <Button x:Name="SettingsBackToMenuButton"
                                    Content="{Binding SettingsBackText}"
                                    Command="{Binding CloseSettingsCommand}"
                                    Style="{StaticResource GameplayCompactButton}"
                                    Margin="0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border x:Name="GameOverOverlay"
                Background="#99000000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsPlayingVisible}" Value="True" />
                                <Condition Binding="{Binding Game.IsGameOver}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border x:Name="GameOverDialog"
                    Width="390"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{StaticResource SettingsSurfaceBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="28">
                <StackPanel>
                    <TextBlock Text="{Binding Game.GameOverTitle}"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding Game.GameOverSummaryText}"
                               Margin="0,8,0,18"
                               FontSize="15"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" />
                    <Border Background="{StaticResource GameplayHudAccentBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14"
                            Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock x:Name="GameOverFinalScoreText"
                                       Text="{Binding Game.FinalScoreText}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="GameOverBestScoreText"
                                       Text="{Binding Game.BestScoreText}"
                                       Margin="0,5,0,0"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <StackPanel x:Name="GameOverActionBar">
                        <Button x:Name="GameOverNewGameButton"
                            Content="{Binding NewGameText}"
                                Command="{Binding NewGameCommand}"
                                Style="{StaticResource MenuPrimaryButton}" />
                        <Button x:Name="GameOverMenuButton"
                                Content="{Binding BackToMenuText}"
                                Command="{Binding BackToMenuCommand}"
                                Style="{StaticResource GameplayCompactButton}"
                                Margin="0,10,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>

