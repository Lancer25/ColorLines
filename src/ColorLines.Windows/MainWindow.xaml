<Window x:Class="ColorLines.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Color Lines"
        Width="1060"
        Height="760"
        MinWidth="820"
        MinHeight="620"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="MenuPrimaryButton" TargetType="Button">
            <Setter Property="Tag" Value="MenuPrimaryButton" />
            <Setter Property="Height" Value="54" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="{StaticResource MenuPrimaryButtonBrush}" />
            <Setter Property="Foreground" Value="#FFFFFB" />
            <Setter Property="BorderBrush" Value="{StaticResource MenuPrimaryButtonHoverBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonFrame"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonFrame" Property="Background" Value="{StaticResource MenuPrimaryButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonFrame" Property="Background" Value="{StaticResource MenuPrimaryButtonPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonFrame" Property="BorderBrush" Value="#FFFFE4B8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuSecondaryButton" TargetType="Button">
            <Setter Property="Tag" Value="MenuSecondaryButton" />
            <Setter Property="Height" Value="46" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="{StaticResource MenuSecondaryButtonBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CellBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonFrame"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonFrame" Property="Background" Value="{StaticResource MenuSecondaryButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonFrame" Property="Background" Value="{StaticResource MenuSecondaryButtonPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonFrame" Property="BorderBrush" Value="{StaticResource MenuPrimaryButtonHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GameplayCompactButton" TargetType="Button" BasedOn="{StaticResource MenuSecondaryButton}">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Tag" Value="MenuSecondaryButton" />
        </Style>

        <Style x:Key="BoardCellButton" TargetType="Button">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{StaticResource CellBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="#D9D0A269" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CellFrame"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CellFrame" Property="Background" Value="{StaticResource CellHoverBrush}" />
                                <Setter TargetName="CellFrame" Property="BorderBrush" Value="#D98B4A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="MainMenuView"
              Margin="28"
              Visibility="{Binding IsMainMenuVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>
            <Border x:Name="MenuBackdrop"
                    Grid.ColumnSpan="2"
                    Background="{StaticResource MenuBackdropBrush}"
                    CornerRadius="18" />

            <Grid x:Name="MenuHeroArea"
                  Grid.Column="0"
                  Margin="30,0,44,0"
                  VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Color Lines"
                               FontSize="54"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Match five cats. Clear the board. Chase your best score."
                               Margin="0,10,0,0"
                               FontSize="18"
                               Foreground="{StaticResource TextMutedBrush}" />
                    <Border x:Name="MenuHeroBoard"
                            Margin="0,30,0,0"
                            Width="460"
                            Height="460"
                            Background="{StaticResource BoardShadowBrush}"
                            BorderBrush="{StaticResource BoardBorderBrush}"
                            BorderThickness="2"
                            CornerRadius="22"
                            Padding="18"
                            HorizontalAlignment="Left">
                        <Border Background="{StaticResource BoardInnerBrush}"
                                CornerRadius="16"
                                Padding="16">
                            <UniformGrid Rows="5" Columns="5">
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4">
                                <Image x:Name="MenuPreviewCatOrange"
                                       Source="/ColorLines.Windows;component/Assets/Themes/CozyBoard/pieces/orange.png"
                                       Width="56"
                                       Height="56"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4">
                                <Image x:Name="MenuPreviewCatBlueGray"
                                       Source="/ColorLines.Windows;component/Assets/Themes/CozyBoard/pieces/bluegray.png"
                                       Width="56"
                                       Height="56"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4">
                                <Image x:Name="MenuPreviewCatTuxedo"
                                       Source="/ColorLines.Windows;component/Assets/Themes/CozyBoard/pieces/tuxedo.png"
                                       Width="56"
                                       Height="56"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4">
                                <Image x:Name="MenuPreviewCatCalico"
                                       Source="/ColorLines.Windows;component/Assets/Themes/CozyBoard/pieces/calico.png"
                                       Width="56"
                                       Height="56"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4">
                                <Image x:Name="MenuPreviewCatWhite"
                                       Source="/ColorLines.Windows;component/Assets/Themes/CozyBoard/pieces/white.png"
                                       Width="56"
                                       Height="56"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4">
                                <Image x:Name="MenuPreviewCatGray"
                                       Source="/ColorLines.Windows;component/Assets/Themes/CozyBoard/pieces/gray.png"
                                       Width="56"
                                       Height="56"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>
                            <Border Background="{StaticResource CellBackgroundBrush}" CornerRadius="10" Margin="4" />
                            </UniformGrid>
                        </Border>
                    </Border>
                </StackPanel>
            </Grid>

            <Border x:Name="MenuCommandPanel"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="28"
                    MinWidth="320">
                <StackPanel>
                    <TextBlock Text="Ready to play"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <StackPanel x:Name="MenuStatusStrip">
                        <TextBlock Text="{Binding Game.HighScore, StringFormat=Best Score: {0}}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding Game.SelectedThemeName, StringFormat=Theme: {0}}"
                                   Margin="0,8,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding Game.AnimationIntensity, StringFormat=Animation: {0}}"
                                   Margin="0,4,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding Game.IsSoundEnabled, StringFormat=Sound: {0}}"
                                   Margin="0,4,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                    <Button x:Name="ContinueButton"
                            Content="Continue"
                            Command="{Binding ContinueCommand}"
                            Style="{StaticResource MenuPrimaryButton}"
                            Margin="0,26,0,0"
                            />
                    <Button x:Name="MenuNewGameButton"
                            Content="New Game"
                            Command="{Binding NewGameCommand}"
                            Style="{StaticResource MenuSecondaryButton}"
                            Margin="0,10,0,0"
                            />
                    <Button x:Name="MenuSettingsButton"
                            Content="Settings"
                            Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource MenuSecondaryButton}"
                            Margin="0,10,0,0"
                            />
                    <Button x:Name="ExitButton"
                            Content="Exit"
                            Command="{Binding ExitCommand}"
                            Style="{StaticResource MenuSecondaryButton}"
                            Margin="0,10,0,0"
                            />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="GameplayView"
              Margin="28"
              Visibility="{Binding IsPlayingVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <Border x:Name="MainBoardFrame"
                    Grid.Column="0"
                    Background="{StaticResource BoardShadowBrush}"
                    BorderBrush="{StaticResource BoardBorderBrush}"
                    BorderThickness="2"
                    CornerRadius="16"
                    Padding="20">
                <Border Background="{StaticResource BoardInnerBrush}"
                        CornerRadius="12"
                        Padding="8">
                    <Viewbox Stretch="Uniform">
                        <ItemsControl ItemsSource="{Binding Game.Cells}" Width="560" Height="560">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="9" Columns="9" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource BoardCellButton}"
                                    Command="{Binding DataContext.Game.SelectCellCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    MouseEnter="BoardCellPointerEntered"
                                    MouseLeave="BoardCellPointerLeft">
                                <Grid Width="52" Height="52">
                                    <Border x:Name="ReachableTargetGlow"
                                            Margin="8"
                                            CornerRadius="16"
                                            Background="#FFFFE1A8"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsReachableTarget}" Value="True">
                                                        <Setter Property="Opacity" Value="0.42" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border x:Name="PathPreviewGlow"
                                            Margin="14"
                                            CornerRadius="14"
                                            Background="#FF7AC7C4"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPathPreview}" Value="True">
                                                        <Setter Property="Opacity" Value="0.55" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border x:Name="MovePathPulseGlow"
                                            Margin="10"
                                            CornerRadius="15"
                                            Background="#FF8FD8D1"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding WasMovePath}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.58"
                                                                                     To="0"
                                                                                     Duration="0:0:0.36" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border x:Name="ClearFeedbackGlow"
                                            Background="#33FF8BA7"
                                            CornerRadius="12"
                                            Margin="3"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding WasCleared}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.42"
                                                                                     To="0"
                                                                                     Duration="0:0:0.28" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border x:Name="ClearPulseGlow"
                                            Background="#77FF7DA4"
                                            BorderBrush="#FFFFD0DD"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Margin="5"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding WasCleared}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.88"
                                                                                     To="0"
                                                                                     Duration="0:0:0.42" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border x:Name="RejectFeedbackGlow"
                                            Background="#36D94B4B"
                                            CornerRadius="12"
                                            Margin="3"
                                            IsHitTestVisible="False">
                                        <Border.RenderTransform>
                                            <TranslateTransform />
                                        </Border.RenderTransform>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding WasRejectedTarget}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.45"
                                                                                     To="0"
                                                                                     Duration="0:0:0.28" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Ellipse x:Name="SpawnFeedbackGlow"
                                             Width="44"
                                             Height="30"
                                             VerticalAlignment="Bottom"
                                             Fill="#5562B96C"
                                             IsHitTestVisible="False">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding WasSpawned}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.55"
                                                                                     To="0"
                                                                                     Duration="0:0:0.34" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <Ellipse x:Name="MoveFeedbackGlow"
                                             Width="44"
                                             Height="30"
                                             VerticalAlignment="Bottom"
                                             Fill="#5568A9FF"
                                             IsHitTestVisible="False">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding WasMovedTo}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.55"
                                                                                     To="0"
                                                                                     Duration="0:0:0.32" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <Ellipse x:Name="PieceBase"
                                             Width="44"
                                             Height="23"
                                             VerticalAlignment="Bottom"
                                             Fill="#55FFF4DC"
                                             IsHitTestVisible="False">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOccupied}" Value="True">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <Ellipse x:Name="PieceShadow"
                                             Width="40"
                                             Height="16"
                                             VerticalAlignment="Bottom"
                                             Fill="#3A24170F"
                                             IsHitTestVisible="False">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOccupied}" Value="True">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <Ellipse Width="47"
                                             Height="34"
                                             VerticalAlignment="Bottom"
                                             Fill="#44FFE06B"
                                             IsHitTestVisible="False">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <Grid x:Name="PieceActor"
                                          RenderTransformOrigin="0.5,0.85"
                                          IsHitTestVisible="False">
                                        <Grid.RenderTransform>
                                            <TranslateTransform Y="0" />
                                        </Grid.RenderTransform>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Margin" Value="0,-3,0,3" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid x:Name="PieceScaleActor"
                                              RenderTransformOrigin="0.5,0.85">
                                            <Grid.RenderTransform>
                                                <ScaleTransform ScaleX="1" ScaleY="1" />
                                            </Grid.RenderTransform>
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding WasMovedTo}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                         From="0.65"
                                                                                         To="1"
                                                                                         Duration="0:0:0.16" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding WasSpawned}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                         From="0.25"
                                                                                         To="1"
                                                                                         Duration="0:0:0.18" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Image x:Name="PieceImage"
                                                   Width="44"
                                                   Height="44"
                                                   Source="{Binding Piece.AssetPath}"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Opacity" Value="0" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOccupied}" Value="True">
                                                                <Setter Property="Opacity" Value="1" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Viewbox>
                </Border>
            </Border>

            <StackPanel x:Name="RightRail" Grid.Column="1" Margin="28,0,0,0">
            <TextBlock Text="Color Lines"
                       FontSize="34"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
            <Border x:Name="StatusTextRegion"
                    MinHeight="58"
                    Margin="0,6,0,18">
                <TextBlock Text="{Binding Game.StatusText}"
                           TextWrapping="Wrap"
                           FontSize="15"
                           Foreground="{StaticResource TextMutedBrush}" />
            </Border>

            <Border x:Name="ScorePanel"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Score"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="13"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Game.Score}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="34"
                               FontWeight="Bold" />
                    <TextBlock Text="{Binding Game.HighScore, StringFormat=Best: {0}}"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <Border x:Name="ScoreDeltaBadge"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Padding="10,4"
                            CornerRadius="8"
                            Background="#FFFFE1A8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Opacity" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Game.ShowScoreDelta}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1"
                                                                     To="0"
                                                                     Duration="0:0:0.85" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding Game.ScoreDeltaBadgeText}"
                                   Foreground="{StaticResource ScoreAccentBrush}"
                                   FontSize="18"
                                   FontWeight="Bold" />
                    </Border>
                </StackPanel>
            </Border>

            <Border x:Name="NextCatsPanel"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Next Cats"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="13"
                               FontWeight="SemiBold" />
                    <ItemsControl ItemsSource="{Binding Game.NextPieces}" Margin="0,10,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource CellHoverBrush}"
                                        CornerRadius="14"
                                        Padding="8"
                                        Margin="0,0,8,0">
                                    <Grid Width="44" Height="40">
                                        <Ellipse Width="34"
                                                 Height="18"
                                                 VerticalAlignment="Bottom"
                                                 Fill="#332C1B14" />
                                        <Image Width="40"
                                               Height="40"
                                               Source="{Binding AssetPath}"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Button x:Name="NewGameButton"
                    Content="New Game"
                    Command="{Binding NewGameCommand}"
                    Height="44"
                    Background="{StaticResource AccentBrush}"
                    Foreground="#FFFFFB"
                    BorderThickness="0"
                    FontSize="15"
                    FontWeight="SemiBold" />

            <Button x:Name="GameplaySettingsButton"
                    Content="Settings"
                    Command="{Binding OpenSettingsCommand}"
                    Height="36"
                    Margin="0,10,0,0"
                    Background="{StaticResource CellHoverBrush}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    BorderBrush="{StaticResource CellBorderBrush}" />
            </StackPanel>
        </Grid>

        <Grid x:Name="SettingsView"
              Margin="28"
              Visibility="{Binding IsSettingsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Width="420"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="26">
                <StackPanel>
                    <TextBlock Text="Settings"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding Game.SelectedThemeName, StringFormat=Theme: {0}}"
                               Margin="0,18,0,0"
                               FontSize="16"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding Game.AnimationIntensity, StringFormat=Animation: {0}}"
                               Margin="0,8,0,0"
                               FontSize="14"
                               Foreground="{StaticResource TextMutedBrush}" />
                    <Button x:Name="SettingsToggleAnimationButton"
                            Content="{Binding Game.AnimationToggleText}"
                            Command="{Binding Game.ToggleAnimationCommand}"
                            Height="40"
                            Margin="0,18,0,0"
                            Background="{StaticResource CellHoverBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderBrush="{StaticResource CellBorderBrush}" />
                    <Button x:Name="SettingsToggleSoundButton"
                            Content="Toggle Sound"
                            Command="{Binding Game.ToggleSoundCommand}"
                            Height="40"
                            Margin="0,10,0,0"
                            Background="{StaticResource CellHoverBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderBrush="{StaticResource CellBorderBrush}" />
                    <TextBlock Text="{Binding Game.IsSoundEnabled, StringFormat=Sound enabled: {0}}"
                               Margin="0,8,0,0"
                               FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}" />
                    <Button x:Name="SettingsBackToMenuButton"
                            Content="Back"
                            Command="{Binding BackToMenuCommand}"
                            Height="42"
                            Margin="0,22,0,0"
                            Background="{StaticResource AccentBrush}"
                            Foreground="#FFFFFB"
                            BorderThickness="0"
                            FontSize="15"
                            FontWeight="SemiBold" />
                </StackPanel>
            </Border>
        </Grid>

        <Border x:Name="GameOverOverlay"
                Background="#99000000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsPlayingVisible}" Value="True" />
                                <Condition Binding="{Binding Game.IsGameOver}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border Width="360"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{StaticResource PanelBackgroundBrush}"
                    CornerRadius="14"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="{Binding Game.GameOverTitle}"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding Game.GameOverSummaryText}"
                               Margin="0,8,0,18"
                               FontSize="15"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" />
                    <Border Background="#FFFFF2CF"
                            BorderBrush="#E8CFB7"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14"
                            Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock x:Name="GameOverFinalScoreText"
                                       Text="{Binding Game.FinalScoreText}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="GameOverBestScoreText"
                                       Text="{Binding Game.BestScoreText}"
                                       Margin="0,5,0,0"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Button Content="New Game"
                            Command="{Binding NewGameCommand}"
                            Height="42"
                            Background="{StaticResource AccentBrush}"
                            Foreground="#FFFFFB"
                            BorderThickness="0"
                            FontSize="15"
                            FontWeight="SemiBold" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
