<Window x:Class="ColorLines.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Color Lines"
        Width="1060"
        Height="760"
        MinWidth="820"
        MinHeight="620"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="BoardCellButton" TargetType="Button">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{StaticResource CellBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CellBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CellFrame"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CellFrame" Property="Background" Value="{StaticResource CellHoverBrush}" />
                                <Setter TargetName="CellFrame" Property="BorderBrush" Value="#D98B4A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource BoardBackgroundBrush}"
                BorderBrush="{StaticResource BoardBorderBrush}"
                BorderThickness="2"
                CornerRadius="16"
                Padding="20">
            <Viewbox Stretch="Uniform">
                <ItemsControl ItemsSource="{Binding Cells}" Width="560" Height="560">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="9" Columns="9" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource BoardCellButton}"
                                    Command="{Binding DataContext.SelectCellCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    MouseEnter="BoardCellPointerEntered"
                                    MouseLeave="BoardCellPointerLeft">
                                <Grid Width="52" Height="52">
                                    <Border x:Name="ReachableTargetGlow"
                                            Margin="8"
                                            CornerRadius="16"
                                            Background="#FFFFE1A8"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsReachableTarget}" Value="True">
                                                        <Setter Property="Opacity" Value="0.42" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border x:Name="PathPreviewGlow"
                                            Margin="14"
                                            CornerRadius="14"
                                            Background="#FF7AC7C4"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPathPreview}" Value="True">
                                                        <Setter Property="Opacity" Value="0.55" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border x:Name="MovePathPulseGlow"
                                            Margin="10"
                                            CornerRadius="15"
                                            Background="#FF8FD8D1"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding WasMovePath}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.58"
                                                                                     To="0"
                                                                                     Duration="0:0:0.36" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border x:Name="ClearFeedbackGlow"
                                            Background="#33FF8BA7"
                                            CornerRadius="12"
                                            Margin="3"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding WasCleared}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.42"
                                                                                     To="0"
                                                                                     Duration="0:0:0.28" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border x:Name="ClearPulseGlow"
                                            Background="#77FF7DA4"
                                            BorderBrush="#FFFFD0DD"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Margin="5"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding WasCleared}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.88"
                                                                                     To="0"
                                                                                     Duration="0:0:0.42" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border x:Name="RejectFeedbackGlow"
                                            Background="#36D94B4B"
                                            CornerRadius="12"
                                            Margin="3"
                                            IsHitTestVisible="False">
                                        <Border.RenderTransform>
                                            <TranslateTransform />
                                        </Border.RenderTransform>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding WasRejectedTarget}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.45"
                                                                                     To="0"
                                                                                     Duration="0:0:0.28" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Ellipse x:Name="SpawnFeedbackGlow"
                                             Width="44"
                                             Height="30"
                                             VerticalAlignment="Bottom"
                                             Fill="#5562B96C"
                                             IsHitTestVisible="False">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding WasSpawned}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.55"
                                                                                     To="0"
                                                                                     Duration="0:0:0.34" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <Ellipse x:Name="MoveFeedbackGlow"
                                             Width="44"
                                             Height="30"
                                             VerticalAlignment="Bottom"
                                             Fill="#5568A9FF"
                                             IsHitTestVisible="False">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding WasMovedTo}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.55"
                                                                                     To="0"
                                                                                     Duration="0:0:0.32" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <Ellipse x:Name="PieceShadow"
                                             Width="36"
                                             Height="17"
                                             VerticalAlignment="Bottom"
                                             Fill="#332C1B14"
                                             IsHitTestVisible="False">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOccupied}" Value="True">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <Ellipse Width="47"
                                             Height="34"
                                             VerticalAlignment="Bottom"
                                             Fill="#44FFE06B"
                                             IsHitTestVisible="False">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <Grid x:Name="PieceActor"
                                          RenderTransformOrigin="0.5,0.85"
                                          IsHitTestVisible="False">
                                        <Grid.RenderTransform>
                                            <TranslateTransform Y="0" />
                                        </Grid.RenderTransform>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Margin" Value="0,-3,0,3" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid x:Name="PieceScaleActor"
                                              RenderTransformOrigin="0.5,0.85">
                                            <Grid.RenderTransform>
                                                <ScaleTransform ScaleX="1" ScaleY="1" />
                                            </Grid.RenderTransform>
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding WasMovedTo}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                         From="0.65"
                                                                                         To="1"
                                                                                         Duration="0:0:0.16" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding WasSpawned}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                         From="0.25"
                                                                                         To="1"
                                                                                         Duration="0:0:0.18" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Image x:Name="PieceImage"
                                                   Width="44"
                                                   Height="44"
                                                   Source="{Binding Piece.AssetPath}"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Opacity" Value="0" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOccupied}" Value="True">
                                                                <Setter Property="Opacity" Value="1" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Viewbox>
        </Border>

        <StackPanel Grid.Column="1" Margin="28,0,0,0">
            <TextBlock Text="Color Lines"
                       FontSize="34"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
            <Border x:Name="StatusTextRegion"
                    MinHeight="58"
                    Margin="0,6,0,18">
                <TextBlock Text="{Binding StatusText}"
                           TextWrapping="Wrap"
                           FontSize="15"
                           Foreground="{StaticResource TextMutedBrush}" />
            </Border>

            <Border Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="#E8CFB7"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Score"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="13"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Score}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="34"
                               FontWeight="Bold" />
                    <TextBlock Text="{Binding HighScore, StringFormat=Best: {0}}"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <Border x:Name="ScoreDeltaBadge"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Padding="10,4"
                            CornerRadius="8"
                            Background="#FFFFE1A8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Opacity" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowScoreDelta}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1"
                                                                     To="0"
                                                                     Duration="0:0:0.85" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding ScoreDeltaBadgeText}"
                                   Foreground="{StaticResource ScoreAccentBrush}"
                                   FontSize="18"
                                   FontWeight="Bold" />
                    </Border>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="#E8CFB7"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Next Cats"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="13"
                               FontWeight="SemiBold" />
                    <ItemsControl ItemsSource="{Binding NextPieces}" Margin="0,10,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource CellHoverBrush}"
                                        CornerRadius="14"
                                        Padding="8"
                                        Margin="0,0,8,0">
                                    <Grid Width="44" Height="40">
                                        <Ellipse Width="34"
                                                 Height="18"
                                                 VerticalAlignment="Bottom"
                                                 Fill="#332C1B14" />
                                        <Image Width="40"
                                               Height="40"
                                               Source="{Binding AssetPath}"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Button Content="New Game"
                    Command="{Binding NewGameCommand}"
                    Height="42"
                    Background="{StaticResource AccentBrush}"
                    Foreground="#FFFFFB"
                    BorderThickness="0"
                    FontSize="15"
                    FontWeight="SemiBold" />

            <Border Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="#E8CFB7"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18"
                    Margin="0,14,0,0">
                <StackPanel>
                    <TextBlock Text="Settings"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="13"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedThemeName}"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="15" />
                    <TextBlock Text="{Binding AnimationIntensity, StringFormat=Animation: {0}}"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="13" />
                    <Button Content="Toggle Sound"
                            Command="{Binding ToggleSoundCommand}"
                            Height="34"
                            Margin="0,12,0,0"
                            Background="{StaticResource CellHoverBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderBrush="{StaticResource CellBorderBrush}" />
                    <TextBlock Text="{Binding IsSoundEnabled, StringFormat=Sound enabled: {0}}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="12" />
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.ColumnSpan="2"
                Background="#99000000"
                Visibility="{Binding IsGameOver, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Width="320"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{StaticResource PanelBackgroundBrush}"
                    CornerRadius="14"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="Game Over"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="The board is full."
                               Margin="0,8,0,20"
                               FontSize="15"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" />
                    <Button Content="New Game"
                            Command="{Binding NewGameCommand}"
                            Height="42"
                            Background="{StaticResource AccentBrush}"
                            Foreground="#FFFFFB"
                            BorderThickness="0"
                            FontSize="15"
                            FontWeight="SemiBold" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
